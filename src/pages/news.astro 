---
import MainLayout from '../layouts/MainLayout.astro';

import fs from 'fs';

const newsDir = './src/content/news';

const files = fs.readdirSync(newsDir);

const news = files.map(file => {
  const content = fs.readFileSync(`${newsDir}/${file}`, 'utf-8');

  return {
    title: content.match(/title: "(.*)"/)?.[1],
    date: content.match(/date: "(.*)"/)?.[1],
    body: content.split('---')[2]
  };
});
---

<MainLayout title="News">

  <h1 style="margin-bottom:40px;">
    News
  </h1>

  {
    news.map(item => (
      <div class="card" style="margin-bottom:20px;">

        <h2>{item.title}</h2>

        <p style="color:#9aa4b2;">
          {item.date}
        </p>

        <div>
          {item.body}
        </div>

      </div>
    ))
  }

</MainLayout>