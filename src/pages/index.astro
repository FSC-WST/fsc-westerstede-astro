---
import MainLayout from '../layouts/MainLayout.astro';

import fs from 'fs';

const content = fs.readFileSync('./src/content/home.md', 'utf-8');

const title =
  content.match(/title: "(.*)"/)?.[1] || '';

const subtitle =
  content.match(/subtitle: "(.*)"/)?.[1] || '';

const body =
  content.split('---')[2] || '';
---

<MainLayout title={title}>

  <section style="padding:80px 0;text-align:center;">

    <h1 style="font-size:3rem;margin-bottom:20px;">
      {title}
    </h1>

    <p style="color:#9aa4b2;font-size:1.2rem;">
      {subtitle}
    </p>

  </section>

  <div class="card">
    {body}
  </div>

</MainLayout>