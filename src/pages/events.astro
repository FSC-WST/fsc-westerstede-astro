---
import MainLayout from '../layouts/MainLayout.astro';

import fs from 'fs';

const eventsDir = './src/content/events';

const files = fs.readdirSync(eventsDir);

const events = files.map(file => {
  const content = fs.readFileSync(`${eventsDir}/${file}`, 'utf-8');

  return {
    title: content.match(/title: "(.*)"/)?.[1],
    date: content.match(/date: "(.*)"/)?.[1],
    location: content.match(/location: "(.*)"/)?.[1],
    body: content.split('---')[2]
  };
});
---

<MainLayout title="Events">

  <section style="padding: 40px 0;">

    <h1
      style="
        font-size: 3rem;
        margin-bottom: 15px;
      "
    >
      📅 Events
    </h1>

    <p
      style="
        color: #9aa4b2;
        margin-bottom: 50px;
        font-size: 1.1rem;
      "
    >
      Alle Termine, Sprungtage und Vereinsveranstaltungen.
    </p>

    {
      events.map(event => (
        <div
          class="card"
          style="
            margin-bottom: 25px;
          "
        >

          <h2
            style="
              margin-bottom: 10px;
            "
          >
            {event.title}
          </h2>

          <div
            style="
              color: #4f7cff;
              margin-bottom: 10px;
              font-weight: 600;
            "
          >
            📆 {event.date}
          </div>

          <div
            style="
              color: #9aa4b2;
              margin-bottom: 20px;
            "
          >
            📍 {event.location}
          </div>

          <div
            style="
              line-height: 1.7;
            "
          >
            {event.body}
          </div>

        </div>
      ))
    }

  </section>

</MainLayout>