---
const {
  title,
  subtitle
} = Astro.props;
---

<section class="hero">

  <h1>{title}</h1>

  <p>{subtitle}</p>

</section>

<style>
  .hero {
    padding: 100px 20px;
    text-align: center;
  }

  .hero h1 {
    font-size: 3.5rem;
    margin-bottom: 20px;
    line-height: 1.1;
  }

  .hero p {
    color: #9aa4b2;
    font-size: 1.2rem;
    max-width: 700px;
    margin: auto;
  }

  @media (max-width: 700px) {
    .hero h1 {
      font-size: 2.3rem;
    }
  }
</style>